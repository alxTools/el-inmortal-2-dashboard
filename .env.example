# Database Configuration (MySQL)
DB_HOST=your-db-host
DB_PORT=3306
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=your-db-name
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false
DB_BACKUP_DIR=C:/path/to/backups/db_artistaviral
DB_BACKUP_RETENTION_DAYS=14
DB_BACKUP_REQUESTED_BY=scheduler
MYSQLDUMP_PATH=C:/Program Files/MySQL/MySQL Workbench 8.0 CE/mysqldump.exe
INTEL_CRED_ENC_KEY=replace-with-strong-random-secret
INTEL_ARTIST_NAME=Galante el Emperador
ASCAP_DEFAULT_WRITER=ALEX ALBERTO SERRANO OLIVENCIA

# YouTube Channel Audit Tool (required for /tools/youtube-metadata-audit)
YT_CLIENT_SECRETS_PATH=C:/path/to/client_secret.json
YT_TOKEN_FILE_PATH=C:/path/to/youtube_token.json

# SEO optimization (Perplexity + top-traffic metadata targets)
PPLX_API_KEY=pplx-your-perplexity-key
PPLX_MODEL=sonar-pro
SEO_PROMPT_TEMPLATE_PATH=C:/path/to/Generate SEO-optimized metadata.md
YT_SEO_TOP_TRAFFIC_LIMIT=50
YT_DAILY_REPORT_TO=team@galanteelemperador.com
YT_REPORT_EMAIL_FROM="El Inmortal 2 Dashboard" <no-reply@galanteelemperador.com>
YT_REPORT_EMAIL_TRANSPORT=smtp
MS_GRAPH_TENANT_ID=your-tenant-id
MS_GRAPH_CLIENT_ID=your-app-client-id
MS_GRAPH_CLIENT_SECRET=your-app-client-secret
MS_GRAPH_SENDER_USER=info@galantealx.com

# Landing page streaming links
LANDING_SPOTIFY_URL=https://open.spotify.com
LANDING_APPLE_MUSIC_URL=https://music.apple.com
LANDING_YOUTUBE_MUSIC_URL=https://music.youtube.com
LANDING_DEEZER_URL=https://www.deezer.com

# OpenAI API (for lyrics transcription)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Dropbox API (for downloading original audio files)
# Get from: https://www.dropbox.com/developers/apps
DROPBOX_ACCESS_TOKEN=your-dropbox-token-here

# Google Drive API (for permanent audio storage)
# Get from: https://console.cloud.google.com
# 1. Create service account
# 2. Enable Google Drive API
# 3. Download JSON key
# 4. Paste entire JSON content here (single line, no line breaks in private_key)
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"..."}

# Optional: Google Drive folder ID (for organizing files)
# GOOGLE_DRIVE_FOLDER_ID=your_folder_id_here

# Session Secret (change this to something random and secure)
SESSION_SECRET=change-this-to-a-random-secret-key
SESSION_COOKIE_NAME=el2.sid
SESSION_MAX_AGE_DAYS=365
SESSION_ROLLING=true
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=lax
SESSION_CLEANUP_INTERVAL_MS=900000

# Admin credentials (for simple auth)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# Debug mode (set to false in production)
DEBUG=false

# Port (default: 3000)
PORT=3000

# Node environment
NODE_ENV=production

# Master API key for /api/v1 (machine-to-machine)
# Example: openssl rand -hex 32
MCP_MASTER_API_KEY=replace-with-strong-random-key

# MCP Configuration
# GitHub Personal Access Token for MCP Server
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_github_token_here

# Cloudflare API Token for MCP Server
# Create at: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id

# Cloudflare Workers AI Gateway
CF_WORKERS_AI_ACCOUNT_ID=your_account_id
CF_WORKERS_AI_GATEWAY_ID=your_gateway_id
CF_WORKERS_AI_TOKEN=your_workers_ai_token

# n8n Webhook Configuration
# URL del webhook de n8n para recibir notificaciones de nuevos registros
# Ejemplo: https://n8n.tudominio.com/webhook/landing-subscriptions
N8N_WEBHOOK_URL=

# Email Configuration for Landing Page
# Remitente de los emails de bienvenida (desde Microsoft Graph)
LANDING_EMAIL_FROM=info@galantealx.com
LANDING_EMAIL_SENDER_NAME=Galante el Emperador
