# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment variables
.env
.env.local
.env.*.local

# Database files (NEVER commit these - they contain live data)
# On Render, the database lives in a persistent disk at /data/database/
database/*.db
database/*.db-journal
database/*.db-shm
database/*.db-wal
!database/.gitkeep

# Logs
logs/
*.log
backups/
downloads/
exports/

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Temporary files
tmp/
temp/
*.tmp

# Build files
dist/
build/

# Test coverage
coverage/
.nyc_output/

# Misc
.cache/
.eslintcache

.vercel

# Local runtime and generated proxy artifacts
n8n_data/
cloudflared.deb
opencode.json
scripts/proxy/generated/
scripts/proxy/PIA_accounts.pdf
scripts/proxy/pia-accounts.csv
scripts/proxy/pia-accounts-inventory.csv

# Local uploaded media assets
public/uploads/audio/
public/uploads/misc/

# Local scratch files
t*corriendo*

# Python cache
__pycache__/
*.pyc
