<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>
    <%- include('../partials/navbar') %>

    <div class="container" style="padding-top: 40px; max-width: 700px;">
        <h1 style="color: #ffd700; margin-bottom: 30px;">💿 Crear Nuevo Álbum</h1>

        <div class="section">
            <form id="albumForm">
                <div class="form-group">
                    <label>Nombre del Álbum *</label>
                    <input type="text" name="name" id="albumName" required placeholder="Ej: El Inmortal 3">
                </div>

                <div class="form-group">
                    <label>Artista *</label>
                    <input type="text" name="artist" id="albumArtist" required placeholder="Ej: Galante el Emperador">
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Fecha de Lanzamiento</label>
                        <input type="date" name="release_date" id="albumReleaseDate">
                    </div>
                    <div class="form-group">
                        <label>Estado</label>
                        <select name="status" id="albumStatus">
                            <option value="upcoming">Próximamente</option>
                            <option value="draft">Borrador</option>
                            <option value="released">Lanzado</option>
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label>Descripción</label>
                    <textarea name="description" id="albumDescription" rows="3" placeholder="Descripción del álbum..."></textarea>
                </div>

                <div style="display: flex; gap: 15px; margin-top: 30px;">
                    <button type="submit" class="btn">💾 Crear Álbum</button>
                    <a href="/albums" class="btn btn-secondary">Cancelar</a>
                </div>
            </form>
        </div>
        
        <!-- Sección de subida masiva (aparece después de crear el álbum) -->
        <div id="bulkUploadSection" style="display: none; margin-top: 30px;" class="section">
            <h3 style="color: #ffd700; margin-bottom: 20px;">📤 Subir Temas en Lote</h3>
            <p style="color: #888; margin-bottom: 15px;">Sube múltiples archivos de audio para este álbum</p>
            <a id="bulkUploadLink" href="#" class="btn" style="display: inline-block;">🎵 Ir a Subida Masiva</a>
        </div>
    </div>

    <%- include('../partials/footer') %>

    <script>
        document.getElementById('albumForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            
            const formData = {
                name: document.getElementById('albumName').value,
                artist: document.getElementById('albumArtist').value,
                release_date: document.getElementById('albumReleaseDate').value,
                status: document.getElementById('albumStatus').value,
                description: document.getElementById('albumDescription').value
            };
            
            try {
                const response = await fetch('/albums', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Accept': 'application/json'
                    },
                    body: JSON.stringify(formData)
                });
                
                const result = await response.json();
                
                if (response.ok && result.data) {
                    // Mostrar opción de subida masiva
                    document.getElementById('bulkUploadSection').style.display = 'block';
                    document.getElementById('bulkUploadLink').href = `/bulk-upload?album_id=${result.data.id}`;
                    
                    // Scroll a la sección de subida
                    document.getElementById('bulkUploadSection').scrollIntoView({ behavior: 'smooth' });
                    
                    alert('✅ Álbum creado exitosamente. Ahora puedes subir los temas en la sección de abajo.');
                } else {
                    alert('Error: ' + (result.error || result.message || 'Error al crear álbum'));
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Error creando álbum');
            }
        });
    </script>
</body>
</html>
