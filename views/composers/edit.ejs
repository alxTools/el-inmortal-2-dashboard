<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>
    <%- include('../partials/navbar') %>

    <div class="container" style="padding-top: 40px; max-width: 700px;">
        <h1 style="color: #ffd700; margin-bottom: 30px;">✏️ Editar Compositor: <%= composer.name %></h1>

        <!-- Avatar Upload Section -->
        <div class="section" style="margin-bottom: 30px; background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 215, 0, 0.3);">
            <h3 style="color: #ffd700; margin-bottom: 20px;">🖼️ Avatar del Compositor</h3>
            
            <div style="display: flex; gap: 30px; align-items: flex-start; flex-wrap: wrap;">
                <!-- Current Avatar -->
                <div style="text-align: center;">
                    <p style="color: #888; margin-bottom: 10px; font-size: 0.9em;">Avatar Actual</p>
                    <div style="width: 150px; height: 150px; border-radius: 50%; overflow: hidden; border: 3px solid #ffd700; background: rgba(255,255,255,0.1); display: flex; align-items: center; justify-content: center;">
                        <% if (composer.avatar_path) { %>
                            <img src="<%= composer.avatar_path %>" alt="<%= composer.name %>" style="width: 100%; height: 100%; object-fit: cover;">
                        <% } else { %>
                            <span style="font-size: 60px;">👤</span>
                        <% } %>
                    </div>
                </div>
                
                <!-- Upload Form -->
                <div style="flex: 1; min-width: 250px;">
                    <form id="avatarUploadForm" enctype="multipart/form-data">
                        <div class="form-group">
                            <label>Cambiar Avatar</label>
                            <input type="file" name="avatar" id="avatarInput" accept="image/*" required
                                   style="padding: 10px; background: rgba(0,0,0,0.3); border: 1px dashed #ffd700; border-radius: 5px; color: #fff; width: 100%;">
                        </div>
                        
                        <div id="avatarPreview" style="display: none; margin: 15px 0;">
                            <p style="color: #888; font-size: 0.9em; margin-bottom: 10px;">Vista previa:</p>
                            <div style="width: 100px; height: 100px; border-radius: 50%; overflow: hidden; border: 2px solid #ffd700;">
                                <img id="avatarPreviewImg" src="" alt="Preview" style="width: 100%; height: 100%; object-fit: cover;">
                            </div>
                        </div>
                        
                        <button type="submit" class="btn" style="margin-top: 10px;">
                            📤 Subir Avatar
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="section">
            <form action="/composers/<%= composer.id %>?_method=PUT" method="POST">
                <div class="form-row">
                    <div class="form-group">
                        <label>Nombre Artístico *</label>
                        <input type="text" name="name" value="<%= composer.name %>" required>
                    </div>
                    <div class="form-group">
                        <label>Nombre Legal</label>
                        <input type="text" name="legal_name" value="<%= composer.legal_name || '' %>" placeholder="Para contratos">
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Email</label>
                        <input type="email" name="email" value="<%= composer.email || '' %>">
                    </div>
                    <div class="form-group">
                        <label>Teléfono</label>
                        <input type="tel" name="phone" value="<%= composer.phone || '' %>">
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Editora (Publisher)</label>
                        <input type="text" name="publisher" value="<%= composer.publisher || '' %>" placeholder="Ej: Universal Music Publishing">
                    </div>
                    <div class="form-group">
                        <label>Afiliación PRO</label>
                        <select name="PRO_affiliation">
                            <option value="">Seleccionar...</option>
                            <option value="ASCAP" <%= composer.PRO_affiliation === 'ASCAP' ? 'selected' : '' %>>ASCAP (USA)</option>
                            <option value="BMI" <%= composer.PRO_affiliation === 'BMI' ? 'selected' : '' %>>BMI (USA)</option>
                            <option value="SESAC" <%= composer.PRO_affiliation === 'SESAC' ? 'selected' : '' %>>SESAC (USA)</option>
                            <option value="SGAE" <%= composer.PRO_affiliation === 'SGAE' ? 'selected' : '' %>>SGAE (España)</option>
                            <option value="SACEM" <%= composer.PRO_affiliation === 'SACEM' ? 'selected' : '' %>>SACEM (Francia)</option>
                            <option value="PRS" <%= composer.PRO_affiliation === 'PRS' ? 'selected' : '' %>>PRS (UK)</option>
                            <option value="BMI PR" <%= composer.PRO_affiliation === 'BMI PR' ? 'selected' : '' %>>BMI PR (Puerto Rico)</option>
                            <option value="ACINPRO" <%= composer.PRO_affiliation === 'ACINPRO' ? 'selected' : '' %>>ACINPRO (Panamá)</option>
                            <option value="SPAC" <%= composer.PRO_affiliation === 'SPAC' ? 'selected' : '' %>>SPAC (Panamá)</option>
                            <option value="sayco_acinpro" <%= composer.PRO_affiliation === 'sayco_acinpro' ? 'selected' : '' %>>SAYCO/ACINPRO (Colombia)</option>
                            <option value="SADAIC" <%= composer.PRO_affiliation === 'SADAIC' ? 'selected' : '' %>>SADAIC (Argentina)</option>
                            <option value="Otro" <%= composer.PRO_affiliation === 'Otro' ? 'selected' : '' %>>Otro</option>
                        </select>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Número IPI/CAE</label>
                        <input type="text" name="IPI_number" value="<%= composer.IPI_number || '' %>" placeholder="Identificador único PRO">
                    </div>
                    <div class="form-group">
                        <label>Splits Estándar</label>
                        <input type="text" name="split_percentage" value="<%= composer.split_percentage || '50/50' %>" placeholder="Ej: 50/50">
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Estado</label>
                        <select name="status">
                            <option value="active" <%= composer.status === 'active' ? 'selected' : '' %>>Activo</option>
                            <option value="inactive" <%= composer.status === 'inactive' ? 'selected' : '' %>>Inactivo</option>
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label>Notas / Información Adicional</label>
                    <textarea name="notes" rows="3" placeholder="Datos importantes sobre el compositor..."><%= composer.notes || '' %></textarea>
                </div>

                <div style="display: flex; gap: 15px; margin-top: 30px;">
                    <button type="submit" class="btn">💾 Actualizar Compositor</button>
                    <a href="/composers" class="btn btn-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </div>

    <%- include('../partials/footer') %>

    <script>
        // Avatar upload handler
        document.getElementById('avatarUploadForm').addEventListener('submit', async function(e) {
            e.preventDefault();

            const formData = new FormData(this);
            const composerId = '<%= composer.id %>';

            try {
                const response = await fetch(`/uploads/avatar/composer/${composerId}`, {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();

                if (response.ok && result.success) {
                    alert('✅ Avatar actualizado exitosamente');
                    location.reload();
                } else {
                    throw new Error(result.error || 'Error al subir avatar');
                }
            } catch (error) {
                console.error('Error:', error);
                alert('❌ Error: ' + error.message);
            }
        });

        // Preview image before upload
        document.getElementById('avatarInput').addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    document.getElementById('avatarPreviewImg').src = e.target.result;
                    document.getElementById('avatarPreview').style.display = 'block';
                };
                reader.readAsDataURL(file);
            }
        });
    </script>
</body>
</html>