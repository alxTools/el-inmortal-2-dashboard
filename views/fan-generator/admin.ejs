<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Fan Generator - Admin</title>
    <link rel="stylesheet" href="/css/dashboard.css">
    <style>
        .loop-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
            gap: 20px;
            margin-top: 20px;
        }
        .loop-card {
            background: rgba(255, 255, 255, 0.05);
            border-radius: 15px;
            padding: 20px;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }
        .loop-preview {
            width: 100%;
            height: 150px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 3em;
            margin-bottom: 15px;
        }
        .upload-area {
            border: 2px dashed rgba(255, 215, 0, 0.3);
            border-radius: 15px;
            padding: 40px;
            text-align: center;
            margin-bottom: 30px;
            transition: all 0.3s;
        }
        .upload-area:hover {
            border-color: rgba(255, 215, 0, 0.6);
            background: rgba(255, 215, 0, 0.05);
        }
    </style>
</head>
<body>
    <%- include('../partials/navbar') %>

    <div class="container" style="padding-top: 40px;">
        <div class="section-header" style="margin-bottom: 30px;">
            <h1>🎬 Fan Generator Admin</h1>
            <a href="/" class="btn btn-secondary">← Volver al Dashboard</a>
        </div>

        <!-- Upload Section -->
        <div class="upload-area" id="uploadArea">
            <p style="font-size: 3em; margin-bottom: 15px;">📁</p>
            <h3>Subir Nuevo Loop</h3>
            <p style="color: #888; margin-bottom: 20px;">Arrastra archivos aquí o haz click para seleccionar</p>
            <input
                type="file"
                id="loopFile"
                accept="video/*,audio/*"
                style="display: none;"
            >
            <div id="uploadForm" style="display: none; margin-top: 20px;">
                <input
                    type="text"
                    id="loopName"
                    placeholder="Nombre del loop"
                    class="form-control"
                    style="margin-bottom: 10px; width: 100%; max-width: 300px;"
                >
                <input
                    type="number"
                    id="loopDuration"
                    placeholder="Duración (segundos)"
                    class="form-control"
                    style="margin-bottom: 15px; width: 100%; max-width: 300px;"
                >
                
                <button onclick="uploadLoop()" class="btn">
                    Subir Loop
                </button>
                <button onclick="cancelUpload()" class="btn btn-secondary" style="margin-left: 10px;">
                    Cancelar
                </button>
            </div>
        </div>

        <!-- Loops List -->
        <h2>Loops Disponibles</h2>
        <div id="loopsList" class="loop-grid">
            <p style="color: #666; text-align: center; grid-column: 1 / -1;">
                Cargando loops...
            </p>
        </div>
    </div>

    <script>
        let selectedFile = null;

        // Setup upload area
        const uploadArea = document.getElementById('uploadArea');
        const fileInput = document.getElementById('loopFile');

        uploadArea.addEventListener('click', () => fileInput.click());
        
        uploadArea.addEventListener('dragover', (e) => {
            e.preventDefault();
            uploadArea.style.borderColor = '#ffd700';
        });
        
        uploadArea.addEventListener('dragleave', () => {
            uploadArea.style.borderColor = 'rgba(255, 215, 0, 0.3)';
        });
        
        uploadArea.addEventListener('drop', (e) => {
            e.preventDefault();
            uploadArea.style.borderColor = 'rgba(255, 215, 0, 0.3)';
            
            if (e.dataTransfer.files.length > 0) {
                handleFileSelect(e.dataTransfer.files[0]);
            }
        });

        fileInput.addEventListener('change', (e) => {
            if (e.target.files.length > 0) {
                handleFileSelect(e.target.files[0]);
            }
        });

        function handleFileSelect(file) {
            selectedFile = file;
            document.getElementById('uploadForm').style.display = 'block';
            document.getElementById('loopName').value = file.name.replace(/\.[^/.]+$/, '');
        }

        function cancelUpload() {
            selectedFile = null;
            document.getElementById('uploadForm').style.display = 'none';
            document.getElementById('loopFile').value = '';
        }

        async function uploadLoop() {
            if (!selectedFile) return;

            const name = document.getElementById('loopName').value;
            const duration = document.getElementById('loopDuration').value;

            if (!name) {
                alert('Ingresa un nombre para el loop');
                return;
            }

            const formData = new FormData();
            formData.append('loop', selectedFile);
            formData.append('name', name);
            formData.append('duration', duration);

            try {
                const response = await fetch('/fan-generator/loops', {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();

                if (result.success) {
                    alert('Loop subido exitosamente');
                    cancelUpload();
                    loadLoops();
                } else {
                    alert('Error: ' + result.error);
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Error subiendo loop');
            }
        }

        async function loadLoops() {
            try {
                const response = await fetch('/fan-generator/loops');
                const result = await response.json();

                const container = document.getElementById('loopsList');

                if (result.success && result.loops.length > 0) {
                    container.innerHTML = result.loops.map(loop => `
                        <div class="loop-card">
                            <div class="loop-preview">🎵</div>
                            <h3>${loop.name}</h3>
                            <p style="color: #888;">Duración: ${loop.duration}s</p>
                            <button 
                                onclick="deleteLoop(${loop.id})" 
                                class="btn-small"
                                style="background: rgba(220, 53, 69, 0.2); color: #ff6b6b; margin-top: 10px;"
                            >
                                🗑️ Eliminar
                            </button>
                        </div>
                    `).join('');
                } else {
                    container.innerHTML = `
                        <p style="color: #666; text-align: center; grid-column: 1 / -1;">
                            No hay loops subidos aún
                        </p>
                    `;
                }
            } catch (error) {
                console.error('Error:', error);
            }
        }

        async function deleteLoop(id) {
            if (!confirm('¿Eliminar este loop?')) return;

            try {
                const response = await fetch(`/fan-generator/loops/${id}`, {
                    method: 'DELETE'
                });

                const result = await response.json();

                if (result.success) {
                    loadLoops();
                } else {
                    alert('Error: ' + result.error);
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Error eliminando loop');
            }
        }

        // Load loops on page load
        loadLoops();
    </script>
</body>
</html>