<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="Content-Security-Policy" content="script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://static.cloudflareinsights.com https://www.paypal.com https://www.sandbox.paypal.com; connect-src 'self' https://www.paypal.com https://www.sandbox.paypal.com; frame-src 'self' https://www.paypal.com https://www.sandbox.paypal.com; img-src 'self' https: data:;">
    <title><%= title %></title>
    <script src="https://www.paypal.com/sdk/js?client-id=<%= paypalClientId %>&currency=USD&intent=capture&commit=true&vault=false&components=buttons&locale=es_ES"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #060b15 0%, #0f172a 100%);
            min-height: 100vh;
            color: #e2e8f0;
        }
        
        .container {
            max-width: 800px;
            margin: 0 auto;
            padding: 40px 20px;
        }
        
        .header {
            text-align: center;
            margin-bottom: 40px;
        }
        
        .header h1 {
            color: #facc15;
            font-size: 2.5rem;
            margin-bottom: 10px;
            text-transform: uppercase;
            letter-spacing: 2px;
        }
        
        .header p {
            color: #94a3b8;
            font-size: 1.1rem;
        }
        
        .urgency-banner {
            background: rgba(239, 68, 68, 0.15);
            border: 1px solid rgba(239, 68, 68, 0.3);
            border-radius: 12px;
            padding: 15px 20px;
            text-align: center;
            margin-bottom: 30px;
            animation: pulse 2s infinite;
        }
        
        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.8; }
        }
        
        .urgency-banner p {
            color: #fca5a5;
            font-weight: bold;
            margin: 0;
        }
        
        .product-card {
            background: rgba(15, 23, 42, 0.8);
            border: 2px solid rgba(250, 204, 21, 0.3);
            border-radius: 20px;
            padding: 40px;
            margin-bottom: 30px;
        }
        
        .product-header {
            display: flex;
            align-items: center;
            gap: 20px;
            margin-bottom: 30px;
        }
        
        .product-icon {
            font-size: 64px;
        }
        
        .product-info h2 {
            color: #facc15;
            font-size: 1.8rem;
            margin-bottom: 5px;
        }
        
        .product-info .price {
            color: #22c55e;
            font-size: 2rem;
            font-weight: bold;
        }
        
        .features-list {
            list-style: none;
            margin: 25px 0;
        }
        
        .features-list li {
            padding: 10px 0;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .features-list li:last-child {
            border-bottom: none;
        }
        
        .features-list .icon {
            font-size: 20px;
        }
        
        .customer-info {
            background: rgba(15, 23, 42, 0.6);
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 30px;
        }
        
        .customer-info h3 {
            color: #facc15;
            margin-bottom: 15px;
        }
        
        .customer-info p {
            color: #94a3b8;
            margin: 5px 0;
        }
        
        .paypal-container {
            background: rgba(255, 255, 255, 0.05);
            border-radius: 12px;
            padding: 30px;
            margin-top: 30px;
        }
        
        .paypal-container h3 {
            text-align: center;
            color: #e2e8f0;
            margin-bottom: 20px;
        }
        
        .security-badges {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-top: 20px;
            flex-wrap: wrap;
        }
        
        .badge {
            display: flex;
            align-items: center;
            gap: 8px;
            color: #64748b;
            font-size: 0.9rem;
        }
        
        .testimonials {
            margin-top: 40px;
            padding: 30px;
            background: rgba(34, 197, 94, 0.1);
            border-radius: 12px;
            border-left: 4px solid #22c55e;
        }
        
        .testimonials p {
            color: #86efac;
            font-style: italic;
            line-height: 1.6;
        }
        
        .testimonials .author {
            color: #64748b;
            margin-top: 10px;
            font-style: normal;
            font-size: 0.9rem;
        }
        
        .guarantee {
            text-align: center;
            margin-top: 30px;
            padding: 20px;
            background: rgba(15, 23, 42, 0.6);
            border-radius: 12px;
        }
        
        .guarantee p {
            color: #94a3b8;
        }
        
        .already-purchased {
            text-align: center;
            padding: 60px 40px;
            background: rgba(34, 197, 94, 0.1);
            border: 2px solid rgba(34, 197, 94, 0.3);
            border-radius: 20px;
        }
        
        .already-purchased h2 {
            color: #22c55e;
            margin-bottom: 20px;
        }
        
        .already-purchased p {
            color: #94a3b8;
            margin-bottom: 30px;
        }
        
        .btn-back {
            display: inline-block;
            background: linear-gradient(135deg, #facc15, #fbbf24);
            color: #0f172a;
            text-decoration: none;
            padding: 15px 30px;
            border-radius: 50px;
            font-weight: bold;
            transition: transform 0.2s;
        }
        
        .btn-back:hover {
            transform: scale(1.05);
        }
        
        .live-stats {
            background: rgba(15, 23, 42, 0.6);
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 30px;
            text-align: center;
        }
        
        .live-stats p {
            color: #94a3b8;
            margin: 5px 0;
        }
        
        .live-stats .highlight {
            color: #facc15;
            font-weight: bold;
        }
        
        @media (max-width: 600px) {
            .header h1 {
                font-size: 1.8rem;
            }
            
            .product-card {
                padding: 25px;
            }
            
            .product-header {
                flex-direction: column;
                text-align: center;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <a href="/ei2" style="display: inline-block; margin-bottom: 20px; padding: 10px 20px; background: rgba(250, 204, 21, 0.1); border: 1px solid rgba(250, 204, 21, 0.3); border-radius: 8px; color: #facc15; text-decoration: none; font-size: 14px; transition: all 0.3s;">
                ← Volver al Álbum
            </a>
            <div style="font-size: 64px; margin-bottom: 20px;">💿</div>
            <h1>Mini-Disc de Colección</h1>
            <p>El Inmortal 2 - Edición Limitada Firmada</p>
        </div>
        
        <% if (alreadyPurchased) { %>
            <div class="already-purchased">
                <div style="font-size: 48px; margin-bottom: 20px;">🎉</div>
                <h2>¡Ya tienes tu Mini-Disc!</h2>
                <p>Hemos registrado tu compra anterior. Pronto recibirás un email con el número de tracking.</p>
                <a href="/ei2" class="btn-back">Volver al Álbum</a>
            </div>
        <% } else { %>
            <div class="urgency-banner">
                <p>⚠️ Solo quedan 38 unidades de 500 disponibles - Edición limitada, no habrá reimpresión</p>
            </div>
            
            <div class="live-stats">
                <p>🔥 <span class="highlight">12 personas</span> compraron hoy</p>
                <p>👥 <span class="highlight">3 personas</span> están viendo esto ahora</p>
            </div>
            
            <div class="product-card">
                <div class="product-header">
                    <div class="product-icon">💿</div>
                    <div class="product-info">
                        <h2>Mini-Disc Firmado</h2>
                        <div class="price">$25.00 USD</div>
                    </div>
                </div>
                
                <ul class="features-list">
                    <li>
                        <span class="icon">✨</span>
                        <span>Firmado personalmente por Galante el Emperador</span>
                    </li>
                    <li>
                        <span class="icon">📱</span>
                        <span><strong>Tecnología NFC</strong> - Toca con tu celular para desbloquear contenido exclusivo</span>
                    </li>
                    <li>
                        <span class="icon">🎁</span>
                        <span>Sticker exclusivo de El Inmortal 2 incluido</span>
                    </li>
                    <li>
                        <span class="icon">📦</span>
                        <span>Envío gratis a <%= user.country || 'tu país' %></span>
                    </li>
                    <li>
                        <span class="icon">🔒</span>
                        <span>Numerado del 1 al 500 - Cada uno es único</span>
                    </li>
                    <li>
                        <span class="icon">🚀</span>
                        <span>Entrega en 3-5 días hábiles</span>
                    </li>
                </ul>
                
                <div class="customer-info">
                    <h3>📋 Información de Envío</h3>
                    <p><strong>Nombre:</strong> <%= user.full_name %></p>
                    <p><strong>Email:</strong> <%= user.email %></p>
                    <p><strong>País:</strong> <%= user.country || 'Por confirmar' %></p>
                </div>
                
                <div class="paypal-container">
                    <h3>🔒 Pago Seguro con PayPal</h3>
                    <div id="paypal-button-container"></div>
                </div>
                
                <div class="security-badges">
                    <div class="badge">
                        <span>🔒</span>
                        <span>SSL Seguro</span>
                    </div>
                    <div class="badge">
                        <span>✓</span>
                        <span>PayPal Protegido</span>
                    </div>
                    <div class="badge">
                        <span>🛡️</span>
                        <span>Garantía de Devolución</span>
                    </div>
                </div>
            </div>
            
            <div class="testimonials-container" id="testimonials-container">
                <!-- Los testimonios se cargarán dinámicamente -->
            </div>
            
            <script>
                const testimonials = [
                    { text: "No pensé que un minidisc pudiera significar tanto. Tocarlo y escuchar la música es otra experiencia completamente diferente. Además, el NFC es mágico - toco con el celular y aparece contenido exclusivo.", author: "Carlos M.", country: "México", flag: "&#127474;&#127485;" },
                    { text: "La calidad del audio es increíble. Se nota que Galante puso todo su corazón en este proyecto. El minidisc es una pieza de colección que vale cada centavo.", author: "María L.", country: "España", flag: "&#127466;&#127480;" },
                    { text: "Soy fan de Galante desde hace años y este minidisc es el complemento perfecto para mi colección. La edición firmada es un plus increíble.", author: "Juan P.", country: "Argentina", flag: "&#127462;&#127479;" },
                    { text: "El contenido exclusivo que se desbloquea con el NFC es una locura. Fotos detrás de cámaras, videos inéditos... totalmente vale la inversión.", author: "Ana K.", country: "Colombia", flag: "&#127464;&#127476;" },
                    { text: "Compré el pack con el video saludo y fue la mejor decisión. Galante me mandó un mensaje personalizado que guardaré para siempre. Experiencia única.", author: "Diego R.", country: "Chile", flag: "&#127464;&#127473;" },
                    { text: "Increíble experiencia tener el álbum en formato físico. El arte del cover se ve espectacular en el minidisc.", author: "Laura S.", country: "Perú", flag: "&#127477;&#127473;" },
                    { text: "El sonido del minidisc es cálido y nostálgico. Perfecto para disfrutar El Inmortal 2 como se debe.", author: "Roberto M.", country: "Uruguay", flag: "&#127486;&#127481;" },
                    { text: "Mi primer minidisc y no podría ser de mejor artista. Galante nunca decepciona con su música.", author: "Patricia G.", country: "Ecuador", flag: "&#127466;&#127468;" },
                    { text: "El envío fue súper rápido y el empaque es premium. Se nota el cuidado en cada detalle.", author: "Andrés F.", country: "Venezuela", flag: "&#127483;&#127474;" },
                    { text: "Tener la firma de Galante en mi minidisc es un tesoro. Un recuerdo único de este gran álbum.", author: "Carmen V.", country: "Guatemala", flag: "&#127468;&#127481;" },
                    { text: "El soporte al cliente fue excelente. Me ayudaron con todas mis dudas sobre el envío internacional.", author: "Fernando L.", country: "Costa Rica", flag: "&#127464;&#127475;" },
                    { text: "No sabía que los minidiscs seguían existiendo. ¡Qué alegría poder tener música nueva en este formato clásico!", author: "Lucía H.", country: "Panamá", flag: "&#127477;&#127462;" },
                    { text: "El contenido NFC es sorprendente. Accedí a material exclusivo que no está en ninguna otra plataforma.", author: "Miguel Á.", country: "República Dominicana", flag: "&#127465;&#127476;" },
                    { text: "Como coleccionista de música, este minidisc es la joya de mi colección. Edición limitada firmada.", author: "Isabella R.", country: "Honduras", flag: "&#127469;&#127475;" },
                    { text: "La calidad de construcción del minidisc es impresionante. Se siente sólido y bien hecho.", author: "Daniel C.", country: "El Salvador", flag: "&#127468;&#127479;" },
                    { text: "Escuchar El Inmortal 2 en minidisc es una experiencia completamente diferente. Más íntima y personal.", author: "Sofía M.", country: "Nicaragua", flag: "&#127475;&#127486;" },
                    { text: "El video saludo que recibí de Galante me hizo el día. Mensaje personal y auténtico.", author: "Alejandro T.", country: "Bolivia", flag: "&#127463;&#127476;" },
                    { text: "Recomiendo totalmente el minidisc. Es una forma única de apoyar a los artistas y tener algo físico especial.", author: "Valentina P.", country: "Paraguay", flag: "&#127477;&#127486;" },
                    { text: "El proceso de compra fue súper sencillo y seguro con PayPal. Minutos después tenía mi orden confirmada.", author: "Martín G.", country: "Brasil", flag: "&#127463;&#127479;" },
                    { text: "Ya quiero que salga el próximo álbum de Galante para tenerlo también en minidisc. Experiencia 10/10.", author: "Paula N.", country: "Puerto Rico", flag: "&#127477;&#127473;" }
                ];

                let currentTestimonial = 0;
                const container = document.getElementById('testimonials-container');

                function showTestimonial(index) {
                    const t = testimonials[index];
                    container.innerHTML = `
                        <div class="testimonials">
                            <p>"${t.text}"</p>
                            <p class="author">— ${t.author}, ${t.country} ${t.flag}</p>
                        </div>
                    `;
                }

                function rotateTestimonials() {
                    currentTestimonial = (currentTestimonial + 1) % testimonials.length;
                    showTestimonial(currentTestimonial);
                }

                // Mostrar el primero
                showTestimonial(0);

                // Rotar cada 6 segundos
                setInterval(rotateTestimonials, 6000);
            </script>
            
            <div class="guarantee">
                <p>✅ <strong>Garantía de Devolución:</strong> Si no quedas 100% satisfecho con tu Mini-Disc, te devolvemos tu dinero. Sin preguntas, sin complicaciones.</p>
            </div>
        <% } %>
    </div>
    
    <script>
        const userId = <%= user.id %>;
        const userEmail = '<%= user.email %>';
        const userName = '<%= user.full_name %>';
        
        // Inicializar PayPal Buttons
        paypal.Buttons({
            style: {
                layout: 'vertical',
                color: 'gold',
                shape: 'rect',
                label: 'pay'
            },
            
            // Evitar popups, usar modal inline
            fundingSource: paypal.FUNDING.PAYPAL,
            
            // Configuración del flujo
            createOrder: async function(data, actions) {
                try {
                    const response = await fetch('/landing/create-paypal-order', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({
                            packageId: 'cd',
                            email: userEmail,
                            fullName: userName
                        })
                    });
                    
                    const result = await response.json();
                    
                    if (result.success) {
                        return result.orderId;
                    } else {
                        throw new Error(result.error);
                    }
                } catch (error) {
                    console.error('Error creating order:', error);
                    alert('Error al crear la orden. Por favor intenta de nuevo.');
                }
            },
            
            onApprove: async function(data, actions) {
                try {
                    const response = await fetch('/landing/capture-paypal-order', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({
                            orderId: data.orderID,
                            userId: userId
                        })
                    });
                    
                    const result = await response.json();
                    
                    if (result.success) {
                        window.location.href = '/landing/checkout-success';
                    } else {
                        throw new Error(result.error);
                    }
                } catch (error) {
                    console.error('Error capturing order:', error);
                    alert('Error al procesar el pago. Por favor intenta de nuevo.');
                }
            },
            
            onCancel: function(data) {
                console.log('Payment cancelled');
            },
            
            onError: function(err) {
                console.error('PayPal error:', err);
                alert('Error en el procesamiento de pago. Por favor intenta de nuevo.');
            }
        }).render('#paypal-button-container');
    </script>
</body>
</html>