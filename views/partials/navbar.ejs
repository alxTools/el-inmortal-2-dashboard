<nav class="navbar">
    <a href="/" class="navbar-brand navbar-brand-logo">
        <img src="/images/galante_signature.png" alt="Galante el Emperador" class="navbar-logo" onerror="this.style.display='none';this.nextElementSibling.style.display='inline';">
        <span class="navbar-logo-fallback" style="display:none;">Galante</span>
    </a>
    
    <!-- Mobile Menu Toggle -->
    <button class="mobile-menu-toggle" id="mobileMenuToggle" aria-label="Toggle menu">
        <span></span>
        <span></span>
        <span></span>
    </button>
    
    <ul class="navbar-nav" id="navbarNav">
        <% if (typeof user !== 'undefined' && user) { %>
            <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
                <!-- ADMIN NAVBAR -->
                <li><a href="/" data-tooltip="Dashboard principal">Dashboard</a></li>
                <li><a href="/albums" data-tooltip="Gestionar álbumes">💿 Álbumes</a></li>
                <li><a href="/tracks" data-tooltip="Lista de temas">🎵 Temas</a></li>
                <li><a href="/producers" data-tooltip="Productores">🎧 Productores</a></li>
                <li><a href="/composers" data-tooltip="Compositores">📝 Compositores</a></li>
                <li><a href="/artists" data-tooltip="Artistas">👥 Artistas</a></li>
                <li><a href="/splitsheets" data-tooltip="Splitsheets">📄 Splitsheets</a></li>
                <li><a href="/calendar" data-tooltip="Calendario">📅 Calendario</a></li>
                <li><a href="/checklist" data-tooltip="Checklist">✅ Checklist</a></li>
                <li><a href="/tools" data-tooltip="Herramientas">🧰 Tools</a></li>
                <li><a href="/ei2" target="_blank" rel="noreferrer" data-tooltip="Ver landing público">🚀 Landing</a></li>
                <li><a href="/settings" data-tooltip="Configuración">⚙️ Config</a></li>
            <% } else { %>
                <!-- FAN NAVBAR -->
                <li><a href="/albums/1" data-tooltip="Ver álbum">🎵 EI2</a></li>
                <li><a href="/splitsheets" data-tooltip="Splitsheets">📄 Splitsheets</a></li>
                <li><a href="/checklist" data-tooltip="Checklist">✅ Checklist</a></li>
                <li><a href="/tools" data-tooltip="Herramientas">🧰 Tools</a></li>
                <li><a href="/settings" data-tooltip="Mi cuenta">⚙️ Config</a></li>
            <% } %>
            <li><a href="/auth/logout" data-tooltip="Cerrar sesión">🚪 Salir</a></li>
        <% } else { %>
            <li><a href="/auth/login">🔐 Login</a></li>
        <% } %>
    </ul>
</nav>

<script>
    // Mobile menu toggle
    document.addEventListener('DOMContentLoaded', function() {
        const mobileMenuToggle = document.getElementById('mobileMenuToggle');
        const navbarNav = document.getElementById('navbarNav');
        
        if (!mobileMenuToggle || !navbarNav) return;
        
        mobileMenuToggle.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            this.classList.toggle('active');
            navbarNav.classList.toggle('active');
        });
        
        navbarNav.querySelectorAll('a').forEach(link => {
            link.addEventListener('click', () => {
                mobileMenuToggle.classList.remove('active');
                navbarNav.classList.remove('active');
            });
        });
        
        document.addEventListener('click', function(e) {
            if (!mobileMenuToggle.contains(e.target) && !navbarNav.contains(e.target)) {
                mobileMenuToggle.classList.remove('active');
                navbarNav.classList.remove('active');
            }
        });
    });
</script>