<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/proxy-mission-control.css">
</head>
<body>
    <main class="mission-shell" data-selected-pool="<%= selectedPool %>">
        <header class="mission-header">
            <div>
                <p class="eyebrow">EL INMORTAL 2 - NETWORK INTEL</p>
                <h1>Proxy Mission Control</h1>
            </div>
            <div class="header-meta">
                <p id="clock">--:--:--</p>
                <p id="refresh-note">Actualizando...</p>
            </div>
        </header>

        <section class="controls">
            <label for="pool-select">Pool</label>
            <select id="pool-select">
                <option value="all">Todos</option>
                <% for (const pool of pools) { %>
                    <option value="<%= pool %>" <%= pool === selectedPool ? 'selected' : '' %>><%= pool %></option>
                <% } %>
            </select>
            <button id="force-refresh" type="button">Refresh Now</button>
        </section>

        <section class="stats-grid">
            <article class="stat-card">
                <h3>Total Tunnels</h3>
                <p id="stat-total">0</p>
            </article>
            <article class="stat-card online">
                <h3>Online</h3>
                <p id="stat-ready">0</p>
            </article>
            <article class="stat-card offline">
                <h3>Offline</h3>
                <p id="stat-down">0</p>
            </article>
            <article class="stat-card">
                <h3>Coverage</h3>
                <p id="stat-cities">0 cities</p>
            </article>
        </section>

        <section class="holo-stage">
            <div class="holo-map" id="holo-map">
                <svg id="holo-lines" class="holo-lines" viewBox="0 0 1000 460" preserveAspectRatio="none"></svg>
                <div id="holo-markers" class="holo-markers"></div>
                <div class="holo-grid"></div>
            </div>

            <aside class="feed-panel">
                <h2>Live Tunnel Feed</h2>
                <ul id="feed-list"></ul>
            </aside>
        </section>
    </main>

    <script>
        window.__MISSION_CONTROL__ = {
            selectedPool: '<%= selectedPool %>',
            pools: <%- JSON.stringify(pools || []) %>
        };
    </script>
    <script src="/js/proxy-mission-control.js"></script>
</body>
</html>
