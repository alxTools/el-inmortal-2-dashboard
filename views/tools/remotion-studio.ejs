<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/dashboard.css">
    <style>
        .studio-container {
            display: flex;
            flex-direction: column;
            height: calc(100vh - 120px);
            background: #1a1a2e;
            border-radius: 12px;
            overflow: hidden;
            margin-top: 20px;
        }
        .studio-header {
            background: #16213e;
            padding: 15px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid #0f3460;
        }
        .studio-header h3 {
            margin: 0;
            color: #fff;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .studio-actions {
            display: flex;
            gap: 10px;
        }
        .studio-iframe {
            flex: 1;
            border: none;
            width: 100%;
            background: #0f0f23;
        }
        .studio-info {
            background: #16213e;
            padding: 15px 20px;
            border-top: 1px solid #0f3460;
        }
        .studio-info p {
            margin: 5px 0;
            color: #9ca3af;
            font-size: 14px;
        }
        .studio-info code {
            background: #1a1a2e;
            padding: 2px 6px;
            border-radius: 4px;
            color: #4fc3f7;
        }
        .btn-launch {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 14px;
            font-weight: 600;
            transition: all 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }
        .btn-launch:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
        }
        .btn-secondary {
            background: #2d3748;
            color: #e2e8f0;
            border: 1px solid #4a5568;
            padding: 10px 20px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 14px;
            transition: all 0.2s;
        }
        .btn-secondary:hover {
            background: #4a5568;
        }
        .btn-back {
            background: transparent;
            color: #9ca3af;
            border: 1px solid #4a5568;
            padding: 8px 16px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 14px;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }
        .btn-back:hover {
            background: #2d3748;
            color: #e2e8f0;
        }
        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
        }
        .status-badge.ready {
            background: rgba(72, 187, 120, 0.2);
            color: #48bb78;
        }
        .status-badge.info {
            background: rgba(66, 153, 225, 0.2);
            color: #4299e1;
        }
        .help-section {
            margin-top: 20px;
            padding: 20px;
            background: #1a1a2e;
            border-radius: 12px;
        }
        .help-section h4 {
            margin: 0 0 15px 0;
            color: #fff;
        }
        .help-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 15px;
        }
        .help-item {
            background: #16213e;
            padding: 15px;
            border-radius: 8px;
            border-left: 3px solid #667eea;
        }
        .help-item h5 {
            margin: 0 0 8px 0;
            color: #fff;
            font-size: 14px;
        }
        .help-item p {
            margin: 0;
            color: #9ca3af;
            font-size: 13px;
        }
    </style>
</head>
<body>
    <%- include('../partials/navbar') %>

    <div class="container" style="padding-top: 30px;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
            <h2 style="margin: 0;"><span class="section-icon">🎬</span> Remotion Studio</h2>
            <a href="/tools" class="btn-back">← Volver a Tools</a>
        </div>

        <div class="studio-container">
            <div class="studio-header">
                <div style="display: flex; align-items: center; gap: 15px;">
                    <h3>
                        🎬 Remotion Studio
                        <span class="status-badge ready">● Listo</span>
                    </h3>
                </div>
                <div class="studio-actions">
                    <button class="btn-secondary" onclick="refreshStudio()">🔄 Recargar</button>
                    <button class="btn-launch" onclick="openStudio()">
                        🚀 Abrir Studio
                    </button>
                    <button class="btn-launch" onclick="renderVideo()" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
                        📹 Render Video
                    </button>
                </div>
            </div>
            
            <iframe 
                id="studioFrame"
                class="studio-iframe"
                src="<%= studioUrl %>"
                sandbox="allow-same-origin allow-scripts allow-popups allow-forms"
            ></iframe>
            
            <div class="studio-info">
                <p><strong>📁 Proyecto:</strong> <code><%= projectPath %></code></p>
                <p><strong>🔌 URL Studio:</strong> <code><%= studioUrl %></code></p>
                <p style="margin-top: 10px; font-size: 12px; color: #6b7280;">
                    💡 Si el iframe no carga, usa el botón "Abrir Studio" para abrirlo en una nueva pestaña.
                </p>
            </div>
        </div>

        <div class="help-section">
            <h4>🎯 Comandos Útiles</h4>
            <div class="help-grid">
                <div class="help-item">
                    <h5>Iniciar Studio</h5>
                    <p><code>npx remotion studio</code></p>
                </div>
                <div class="help-item">
                    <h5>Render Video</h5>
                    <p><code>npx remotion render MyComp out/video.mp4</code></p>
                </div>
                <div class="help-item">
                    <h5>Preview Composición</h5>
                    <p><code>npx remotion preview MyComp</code></p>
                </div>
                <div class="help-item">
                    <h5>Still (Imagen)</h5>
                    <p><code>npx remotion still MyComp out/frame.png</code></p>
                </div>
            </div>
        </div>
    </div>

    <%- include('../partials/footer') %>

    <script>
        function openStudio() {
            window.open('<%= studioUrl %>', '_blank', 'width=1400,height=900');
        }
        
        function refreshStudio() {
            document.getElementById('studioFrame').src = document.getElementById('studioFrame').src;
        }
        
        function renderVideo() {
            if (confirm('¿Renderizar el video? Esto puede tomar varios minutos.')) {
                fetch('/tools/remotion-studio/render', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        composition: 'MyComp',
                        output: 'exports/remotion-output.mp4'
                    })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        alert('✅ Video renderizado: ' + data.outputPath);
                    } else {
                        alert('❌ Error: ' + data.error);
                    }
                })
                .catch(err => {
                    alert('❌ Error: ' + err.message);
                });
            }
        }
    </script>
</body>
</html>
