<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>
    <%- include('../partials/navbar') %>

    <div class="container" style="padding-top: 40px; max-width: 700px;">
        <h1 style="color: #ffd700; margin-bottom: 30px;">🎵 Agregar Nuevo Tema</h1>

        <div class="section">
            <form action="/tracks" method="POST" enctype="multipart/form-data">
                <div class="form-row">
                    <div class="form-group">
                        <label>Número de Track (1-21)</label>
                        <input type="number" name="track_number" min="1" max="21" required>
                    </div>
                    <div class="form-group">
                        <label>Título del Tema</label>
                        <input type="text" name="title" required>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Productor</label>
                        <select name="producer_id">
                            <option value="">Seleccionar...</option>
                            <% producers.forEach(producer => { %>
                                <option value="<%= producer.id %>"><%= producer.name %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Fecha de Grabación</label>
                        <input type="date" name="recording_date">
                    </div>
                </div>

                <div class="form-group" style="background: rgba(255,215,0,0.05); padding: 20px; border-radius: 10px; border: 2px dashed rgba(255,215,0,0.3);">
                    <label style="color: #ffd700; font-weight: bold; display: flex; align-items: center; gap: 8px;">
                        🎵 Archivo de Audio (WAV, MP3, M4A)
                    </label>
                    <input type="file" name="audio_file" accept="audio/*" style="margin-top: 10px; padding: 10px; width: 100%;">
                    <small style="color: #888; display: block; margin-top: 8px;">
                        📤 Se extraerá automáticamente la duración y se generará una descripción AI del track
                    </small>
                </div>

                <div class="form-group">
                    <label>Letras/Notas</label>
                    <textarea name="lyrics" rows="4" placeholder="Letras o notas del tema..."></textarea>
                </div>

                <div style="display: flex; gap: 15px; margin-top: 30px;">
                    <button type="submit" class="btn">💾 Guardar Tema</button>
                    <a href="/tracks" class="btn btn-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </div>

    <%- include('../partials/footer') %>
</body>
</html>